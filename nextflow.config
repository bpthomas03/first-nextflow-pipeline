/*
 * Nextflow config: Docker, defaults, and process settings
 */

// Use Docker for containers (use Singularity on HPC)
docker.enabled = true

// Optional: use a specific Docker daemon
// docker.runOptions = '-u \$(id -u):\$(id -g)'

// Default pipeline params (overridable by -param on CLI)
params {
    outdir = 'results'
}

// Profile for running tests: output to tests/results so main results/ is untouched
profiles {
    test {
        params {
            outdir = 'tests/results'
        }
    }
}

// Process defaults: publish outputs to results/
process {
    withName: 'FASTQC' {
        publishDir = [ path: "${params.outdir}/fastqc", mode: 'copy' ]
    }
    withName: 'BWA_INDEX' {
        publishDir = [ path: "${params.outdir}/bwa_index", mode: 'copy' ]
    }
    withName: 'BWA_MEM' {
        publishDir = [ path: "${params.outdir}/alignments", mode: 'copy', pattern: '*.sam' ]
    }
    withName: 'SAMTOOLS_SORT' {
        publishDir = [ path: "${params.outdir}/alignments", mode: 'copy' ]
    }
    withName: 'MULTIQC' {
        publishDir = [ path: "${params.outdir}/multiqc", mode: 'copy' ]
    }
}
